{
  // 设置默认格式化工具为 Prettier
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,

  // 在保存时进行自动代码修复与 Import 优化
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },

  // 针对特定文件类型的格式化
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // 文件搜索与显示过滤，屏蔽编译、缓存与依赖等无用目录，极大提升全局检索速度
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.next": true,
    "**/dist": true,
    "**/out": true,
    "**/.turbo": true,
    "**/node_modules": true,
    "**/.expo": true
  },

  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/out": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/pnpm-lock.yaml": true
  },

  // Tailwind CSS 智能提示设置
  "tailwindCSS.includeLanguages": {
    "plaintext": "ts"
  }
}
